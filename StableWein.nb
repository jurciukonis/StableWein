Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"wbLoadBinariesPac", ",", 
    RowBox[{"wbBrancNecCond2", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"wbBinDirect", ",", "\"\<wbBrancNecCond2.wdx\>\""}], "}"}], 
       "]"}], "]"}]}], ",", 
    RowBox[{"wbBrancNecCond2", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"par", ",", "_Real", ",", "1"}], "}"}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
           "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3", ",", 
           "sqa1", ",", "sqa2", ",", "sqa3", ",", "t1", ",", "t2", ",", "t3", 
           ",", "y1", ",", "y2", ",", "y3", ",", "z1", ",", "z2", ",", "z3", 
           ",", "cAd1m", ",", "cAd2m", ",", "cAd3m", ",", "at", ",", "test1", 
           ",", "test2"}], "}"}], ",", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"test1", "=", 
           RowBox[{"test2", "=", "False"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
             "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3"}], 
            "}"}], "=", "par"}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"sqa1", ",", "sqa2", ",", "sqa3"}], "}"}], "=", 
           RowBox[{"Sqrt", "/@", 
            RowBox[{"{", 
             RowBox[{"a1", ",", "a2", ",", "a3"}], "}"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"y1", ",", "y2", ",", "y3"}], "}"}], "=", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"c1", "+", "d1"}], ",", 
             RowBox[{"c2", "+", "d2"}], ",", 
             RowBox[{"c3", "+", "d3"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"z1", ",", "z2", ",", "z3"}], "}"}], "=", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"c1", "-", "d1"}], ",", 
             RowBox[{"c2", "-", "d2"}], ",", 
             RowBox[{"c3", "-", "d3"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"cAd1m", ",", "cAd2m", ",", "cAd3m"}], "}"}], "=", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"c1", "-", 
              RowBox[{"Abs", "[", "d1", "]"}]}], ",", 
             RowBox[{"c2", "-", 
              RowBox[{"Abs", "[", "d2", "]"}]}], ",", 
             RowBox[{"c3", "-", 
              RowBox[{"Abs", "[", "d3", "]"}]}]}], "}"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"t1", ",", "t2", ",", "t3"}], "}"}], "=", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"b1", "+", 
              RowBox[{"sqa2", "*", "sqa3"}]}], ",", 
             RowBox[{"b2", "+", 
              RowBox[{"sqa1", "*", "sqa3"}]}], ",", 
             RowBox[{"b3", "+", 
              RowBox[{"sqa1", "*", "sqa2"}]}]}], "}"}]}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"at", "=", 
           RowBox[{
            RowBox[{"sqa1", " ", "sqa2", " ", "sqa3"}], "+", 
            RowBox[{"sqa1", " ", "b1"}], "+", 
            RowBox[{"sqa2", " ", "b2"}], "+", 
            RowBox[{"sqa3", " ", "b3"}]}]}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"--", 
            RowBox[{"--", 
             RowBox[{"--", 
              RowBox[{
               RowBox[{
                RowBox[{"NCL2", "--"}], "--"}], "--"}]}]}]}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"test1", "=", 
             RowBox[{"And", "@@", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"sqa3", " ", "z3"}], "+", 
                  RowBox[{
                   SqrtBox["2"], " ", 
                   SqrtBox[
                    RowBox[{"t1", " ", "t2", " ", 
                    RowBox[{"(", 
                    RowBox[{"t3", "+", "z3"}], ")"}]}]]}]}], 
                 "\[GreaterEqual]", 
                 RowBox[{"-", "at"}]}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"sqa2", " ", "z2"}], "+", 
                  RowBox[{
                   SqrtBox["2"], " ", 
                   SqrtBox[
                    RowBox[{"t1", " ", "t3", " ", 
                    RowBox[{"(", 
                    RowBox[{"t2", "+", "z2"}], ")"}]}]]}]}], 
                 "\[GreaterEqual]", 
                 RowBox[{"-", "at"}]}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"sqa1", " ", "z1"}], "+", 
                  RowBox[{
                   SqrtBox["2"], " ", 
                   SqrtBox[
                    RowBox[{"t2", " ", "t3", " ", 
                    RowBox[{"(", 
                    RowBox[{"t1", "+", "z1"}], ")"}]}]]}]}], 
                 "\[GreaterEqual]", 
                 RowBox[{"-", "at"}]}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"sqa1", " ", "y1"}], "+", 
                  RowBox[{
                   SqrtBox["2"], " ", 
                   SqrtBox[
                    RowBox[{"t2", " ", "t3", " ", 
                    RowBox[{"(", 
                    RowBox[{"t1", "+", "y1"}], ")"}]}]]}]}], 
                 "\[GreaterEqual]", 
                 RowBox[{"-", "at"}]}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"sqa2", " ", "y2"}], "+", 
                  RowBox[{
                   SqrtBox["2"], " ", 
                   SqrtBox[
                    RowBox[{"t1", " ", "t3", " ", 
                    RowBox[{"(", 
                    RowBox[{"t2", "+", "y2"}], ")"}]}]]}]}], 
                 "\[GreaterEqual]", 
                 RowBox[{"-", "at"}]}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"sqa3", " ", "y3"}], "+", 
                  RowBox[{
                   SqrtBox["2"], " ", 
                   SqrtBox[
                    RowBox[{"t1", " ", "t2", " ", 
                    RowBox[{"(", 
                    RowBox[{"t3", "+", "y3"}], ")"}]}]]}]}], 
                 "\[GreaterEqual]", 
                 RowBox[{"-", "at"}]}]}], "}"}]}]}], ";"}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"test1", "=", 
           RowBox[{"And", "@@", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"sqa1", " ", "cAd1m"}], "+", 
                RowBox[{
                 SqrtBox["2"], " ", 
                 SqrtBox[
                  RowBox[{"t2", " ", "t3", " ", 
                   RowBox[{"(", 
                    RowBox[{"cAd1m", "+", "t1"}], ")"}]}]]}]}], ">=", 
               RowBox[{"-", "at"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"sqa2", " ", "cAd2m"}], "+", 
                RowBox[{
                 SqrtBox["2"], " ", 
                 SqrtBox[
                  RowBox[{"t1", " ", 
                   RowBox[{"(", 
                    RowBox[{"cAd2m", "+", "t2"}], ")"}], " ", "t3"}]]}]}], ">=", 
               RowBox[{"-", "at"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"sqa3", " ", "cAd3m"}], "+", 
                RowBox[{
                 SqrtBox["2"], " ", 
                 SqrtBox[
                  RowBox[{"t1", " ", "t2", " ", 
                   RowBox[{"(", 
                    RowBox[{"cAd3m", "+", "t3"}], ")"}]}]]}]}], ">=", 
               RowBox[{"-", "at"}]}]}], "}"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"test1", "==", "False"}], ",", 
            RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"--", 
            RowBox[{"--", 
             RowBox[{"--", 
              RowBox[{
               RowBox[{
                RowBox[{"NCL3", "--"}], "--"}], "--"}]}]}]}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"test2", "=", 
           RowBox[{"And", "@@", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"sqa1", " ", "y1"}], "+", 
                RowBox[{"sqa2", " ", "y2"}], "+", 
                RowBox[{"sqa3", " ", "y3"}], "+", 
                RowBox[{
                 SqrtBox["2"], " ", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"t1", "+", "y1"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t2", "+", "y2"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t3", "+", "y3"}], ")"}]}]]}]}], 
               "\[GreaterEqual]", 
               RowBox[{"-", "at"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"sqa1", " ", "y1"}], "+", 
                RowBox[{"sqa2", " ", "z2"}], "+", 
                RowBox[{"sqa3", " ", "z3"}], "+", 
                RowBox[{
                 SqrtBox["2"], " ", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"t1", "+", "y1"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t2", "+", "z2"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t3", "+", "z3"}], ")"}]}]]}]}], 
               "\[GreaterEqual]", 
               RowBox[{"-", "at"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"sqa2", " ", "y2"}], "+", 
                RowBox[{"sqa1", " ", "z1"}], "+", 
                RowBox[{"sqa3", " ", "z3"}], "+", 
                RowBox[{
                 SqrtBox["2"], " ", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"t2", "+", "y2"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t1", "+", "z1"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t3", "+", "z3"}], ")"}]}]]}]}], 
               "\[GreaterEqual]", 
               RowBox[{"-", "at"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"sqa3", " ", "y3"}], "+", 
                RowBox[{"sqa1", " ", "z1"}], "+", 
                RowBox[{"sqa2", " ", "z2"}], "+", 
                RowBox[{
                 SqrtBox["2"], " ", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"t3", "+", "y3"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t1", "+", "z1"}], ")"}], " ", 
                   RowBox[{"(", 
                    RowBox[{"t2", "+", "z2"}], ")"}]}]]}]}], 
               "\[GreaterEqual]", 
               RowBox[{"-", "at"}]}]}], "}"}]}]}], ";", "\[IndentingNewLine]",
           "\[IndentingNewLine]", 
          RowBox[{"And", "[", 
           RowBox[{"test1", ",", "test2"}], "]"}]}]}], "\[IndentingNewLine]", 
        "]"}], ",", 
       RowBox[{"Parallelization", "\[Rule]", "True"}], ",", 
       RowBox[{"CompilationTarget", "\[Rule]", "wpCompTargetPac"}]}], 
      "]"}]}]}], "]"}], ";"}]], "Input",
