         RowBox[{
          RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
            "ShowStatus", "[", 
             "\"\<Performing numerical minimization of the quartic part of \
the scalar potential...\>\"", "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"bndT", "=", 
             RowBox[{"{", 
              RowBox[{
               SuperscriptBox["10", "5"], ",", 
               SuperscriptBox["10", "4"], ",", "700", ",", "200", ",", "20", 
               ",", "1"}], "}"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"GeneratePoints", "==", "False"}], "||", 
                 RowBox[{"NeuralNets", "==", "True"}]}], ",", 
                RowBox[{"falseBFB", "=", 
                 RowBox[{"Pick", "[", 
                  RowBox[{"falseBFB", ",", 
                   RowBox[{"ParallelMap", "[", 
                    RowBox[{"wbBrancNecCond1", ",", "falseBFB"}], "]"}]}], 
                  "]"}]}]}], "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
            RowBox[{"validSet", "=", 
             RowBox[{"Pick", "[", 
              RowBox[{"falseBFB", ",", 
               RowBox[{"ParallelMap", "[", 
                RowBox[{"wbBrancNecCond2", ",", "falseBFB"}], "]"}]}], 
              "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"validSet", "=", 
             RowBox[{"Pick", "[", 
              RowBox[{"validSet", ",", 
               RowBox[{"ParallelMap", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"wbMinimFuncPotBranc", "[", 
                   RowBox[{"#", ",", "bndT"}], "]"}], "&"}], ",", 
                 "validSet"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"(*", 
