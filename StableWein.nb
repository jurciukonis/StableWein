Cell[TextData[{
 "Setting wpCompTarget = \[OpenCurlyDoubleQuote]WVM\[CloseCurlyDoubleQuote]|\
\[CloseCurlyDoubleQuote]C\[CloseCurlyDoubleQuote] controls the compilation of \
certain functions via ",
 ButtonBox["Compile",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Compile"],
 ", using the corresponding value of the ",
 ButtonBox["CompilationTarget",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/CompilationTarget"],
 " option. Value \[OpenCurlyDoubleQuote]WVM\[CloseCurlyDoubleQuote] (default) \
compiles to  Wolfram virtual machine code (bytecode), the value \
\[OpenCurlyDoubleQuote]C\[CloseCurlyDoubleQuote] to the binary code. In order \
to use \[OpenCurlyDoubleQuote]C\[CloseCurlyDoubleQuote] compilation target C \
compiler should be installed. "
}], "Text",
 CellChangeTimes->{{3.9784306196383944`*^9, 3.978430646398156*^9}, {
  3.9784310724460583`*^9, 3.978431115575212*^9}, {3.978443153928362*^9, 
