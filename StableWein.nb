              RowBox[{"Table", "[", 
               RowBox[{"0.", ",", 
                RowBox[{"{", "13", "}"}]}], "]"}]}], ";", " ", 
             "\[IndentingNewLine]", 
             RowBox[{"dataTT", "=", 
              RowBox[{"ParallelTable", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"dataT", "=", 
                  RowBox[{"Table", "[", 
