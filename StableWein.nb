Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "wbBrancUniBFBcheck", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<GeneratePoints\>\"", "\[Rule]", "True"}], ",", 
     RowBox[{"\"\<ImposeUNI\>\"", "\[Rule]", "True"}], ",", 
     RowBox[{"\"\<ImposeBFB\>\"", "\[Rule]", "True"}], ",", 
     RowBox[{"\"\<NeuralNets\>\"", "\[Rule]", "False"}], ",", 
     RowBox[{"\"\<ExportData\>\"", "\[Rule]", "False"}], ",", 
     RowBox[{"\"\<ShowMessages\>\"", "\[Rule]", "True"}], ",", 
     RowBox[{"\"\<NPoints\>\"", "\[Rule]", 
      SuperscriptBox["10", "3"]}], ",", 
     RowBox[{"\"\<MaxCoupling\>\"", "\[Rule]", "16"}], ",", 
     RowBox[{"\"\<BoundUNI\>\"", "\[Rule]", 
      RowBox[{"8", " ", "\[Pi]"}]}], ",", 
     RowBox[{"\"\<FileNameInit\>\"", "\[Rule]", "\"\<initial_set.csv\>\""}], 
     ",", 
     RowBox[{"\"\<FileNameValid\>\"", "\[Rule]", "\"\<valid_set.csv\>\""}]}], 
    "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9791466215966454`*^9, 3.979146638203738*^9}, 
   3.97914669687204*^9, {3.979736405175179*^9, 3.9797364063149347`*^9}},
 CellLabel->"In[98]:=",ExpressionUUID->"397bc4bc-8450-4c8e-bbfc-7a4f1305f389"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"wbBrancUniBFBcheck", "[", 
    RowBox[{"mode_", ",", 
     RowBox[{"op", ":", 
      RowBox[{"OptionsPattern", "[", "wbBrancUniBFBcheck", "]"}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "initialSet", ",", "predictedSet", ",", "SufBool", ",", "trueBFB", ",", 
       "falseBFB", ",", "timeNETS", ",", "timeGEN", ",", "timeSUF", ",", 
       "timeNEC", ",", "validSet", ",", "\[IndentingNewLine]", "testT", ",", 
       "paramT", ",", "bndT", ",", "dataT", ",", "dataTT", ",", "netPred", 
       ",", "end0", ",", "end", ",", "zeroTabl", ",", "stringT", ",", 
       "\[IndentingNewLine]", "GeneratePoints", ",", "ImposeUNI", ",", 
       "ImposeBFB", ",", "NeuralNets", ",", "ExportData", ",", "ShowMessages",
        ",", "NPoints", ",", "MaxCoupling", ",", "BoundUNI", ",", 
       "FileNameInit", ",", "FileNameValid"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "GeneratePoints", ",", "ImposeUNI", ",", "ImposeBFB", ",", 
         "NeuralNets", ",", "ExportData", ",", "ShowMessages", ",", "NPoints",
          ",", "MaxCoupling", ",", "BoundUNI", ",", "FileNameInit", ",", 
         "FileNameValid"}], "}"}], "=", 
       RowBox[{
        RowBox[{
         RowBox[{"OptionValue", "[", 
          RowBox[{"First", "[", "#", "]"}], "]"}], "&"}], "/@", 
        RowBox[{"Options", "[", "wbBrancUniBFBcheck", "]"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"--", 
          RowBox[{"--", 
           RowBox[{"--", 
            RowBox[{"--", 
             RowBox[{"--", 
              RowBox[{"--", 
               RowBox[{"--", 
                RowBox[{"-", "Predictions"}]}]}]}]}]}]}]}], " ", "of", " ", 
         "neural", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"networks", "--"}], "--"}], "--"}]}], "-", 
        RowBox[{"-", 
         RowBox[{"--", 
          RowBox[{"--", 
           RowBox[{"--", "-"}]}]}]}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"NeuralNets", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"timeNETS", "=", 
          RowBox[{
           RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{
             "ShowStatus", "[", 
              "\"\<Generating initial data set using neural networks...\>\"", 
              "]"}], ";", "\[IndentingNewLine]", 
             RowBox[{"zeroTabl", "=", 
              RowBox[{"Table", "[", 
               RowBox[{"0.", ",", 
                RowBox[{"{", "12", "}"}]}], "]"}]}], ";", " ", 
             "\[IndentingNewLine]", 
             RowBox[{"dataTT", "=", 
              RowBox[{"ParallelTable", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"dataT", "=", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{"wbBrancParRndUniNec", "[", "]"}], ",", 
                    RowBox[{"{", 
                    SuperscriptBox["10", "6"], "}"}]}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"Do", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"netPred", "=", 
                    RowBox[{
                    RowBox[{"wbNetBrancList", "[", 
                    RowBox[{"[", "xx", "]"}], "]"}], "[", "dataT", "]"}]}], 
                    ";", "\[IndentingNewLine]", 
                    RowBox[{"dataT", "=", 
                    RowBox[{"DeleteCases", "[", 
                    RowBox[{
                    RowBox[{"Thread", "[", 
                    RowBox[{"dataT", "->", "netPred"}], "]"}], ",", 
                    RowBox[{"_", "->", "0"}]}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "dataT", "]"}], "==", "0"}], ",", 
                    RowBox[{"dataT", "=", 
                    RowBox[{"{", 
                    RowBox[{"zeroTabl", "->", "0"}], "}"}]}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"dataT", "=", 
                    RowBox[{"dataT", "[", 
                    RowBox[{"[", 
                    RowBox[{";;", ",", "1"}], "]"}], "]"}]}]}], 
                   "\[IndentingNewLine]", ",", 
                   RowBox[{"{", 
                    RowBox[{"xx", ",", "1", ",", 
                    RowBox[{"Length", "[", "wbNetBrancList", "]"}]}], "}"}]}],
                   "]"}], ";", "\[IndentingNewLine]", "dataT"}], 
                "\[IndentingNewLine]", ",", 
                RowBox[{"{", 
                 RowBox[{"Ceiling", "[", 
                  RowBox[{"NPoints", "/", "180."}], "]"}], "}"}]}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"predictedSet", "=", 
              RowBox[{"Flatten", "[", 
               RowBox[{"dataTT", ",", "1"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"initialSet", "=", 
              RowBox[{"Pick", "[", 
               RowBox[{"predictedSet", ",", 
                RowBox[{"ParallelMap", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"wbBrancUNICond", "[", 
