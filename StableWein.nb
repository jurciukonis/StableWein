                "]"}], "<>", "\"\< sec.\>\""}], ",", "Black", ",", 
              RowBox[{"FontSize", "->", "14"}]}], "]"}], "]"}], ",", 
           RowBox[{"Print", "[", 
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{
              "\"\<Run time of the BFB enforcement (mode \>\"", "<>", 
               RowBox[{"ToString", "[", "mode", "]"}], "<>", "\"\<): \>\"", "<>",
                " ", 
