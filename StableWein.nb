Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"wbLoadBinariesPac", ",", 
    RowBox[{"wbBrancSufCond", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"wbBinDirect", ",", "\"\<wbBrancSufCond.wdx\>\""}], "}"}], 
       "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"wbBrancSufCond", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"par", ",", "_Real", ",", "1"}], "}"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a1", ",", "b1", ",", "c1", ",", "d1", ",", "a2", ",", "b2", ",", 
           "c2", ",", "d2", ",", "a3", ",", "b3", ",", "c3", ",", "d3", ",", 
           "g1", ",", "g2", ",", "g3", ",", "g1bar", ",", "g2bar", ",", 
           "g3bar", ",", "f1", ",", "f2", ",", "f3"}], "}"}], ",", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
             "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3"}], 
            "}"}], "=", "par"}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Boto", ",", " ", 
            RowBox[{
             RowBox[{
             "Romao", " ", "and", " ", "Silva", " ", "sufficient", " ", 
              "conditions", " ", "from", " ", 
              RowBox[{"https", ":"}]}], "//", 
             RowBox[{
              RowBox[{
               RowBox[{"arxiv", ".", "org"}], "/", "pdf"}], "/", 
              "2208.01068"}]}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"a1", "<", "0"}], "||", 
             RowBox[{"a2", "<", "0"}], "||", 
             RowBox[{"a3", "<", "0"}]}], ",", 
            RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"g1", "=", 
           RowBox[{"b1", "+", 
            RowBox[{"Min", "[", 
             RowBox[{"0", ",", "c1"}], "]"}], "-", 
            RowBox[{"Abs", "[", "d1", "]"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"g2", "=", 
           RowBox[{"b2", "+", 
            RowBox[{"Min", "[", 
             RowBox[{"0", ",", "c2"}], "]"}], "-", 
            RowBox[{"Abs", "[", "d2", "]"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"g3", "=", 
           RowBox[{"b3", "+", 
            RowBox[{"Min", "[", 
             RowBox[{"0", ",", "c3"}], "]"}], "-", 
            RowBox[{"Abs", "[", "d3", "]"}]}]}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"g1bar", "=", 
           RowBox[{"g1", "+", 
            SqrtBox[
             RowBox[{"a2", " ", "a3"}]]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"g2bar", "=", 
           RowBox[{"g2", "+", 
            SqrtBox[
             RowBox[{"a3", " ", "a1"}]]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"g3bar", "=", 
           RowBox[{"g3", "+", 
            SqrtBox[
             RowBox[{"a1", " ", "a2"}]]}]}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"g1bar", ">=", "0"}], "&&", 
             RowBox[{"g2bar", ">=", "0"}], "&&", 
             RowBox[{"g3bar", ">=", "0"}], "&&", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               SqrtBox[
                RowBox[{"a1", " ", "a2", " ", "a3"}]], "+", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"g1", 
                  SqrtBox["a1"]}], "+", 
                 RowBox[{"g2", 
                  SqrtBox["a2"]}], "+", 
                 RowBox[{"g3", 
                  SqrtBox["a3"]}]}], ")"}], "+", 
               SqrtBox[
                RowBox[{"2", " ", "g1bar", " ", "g2bar", " ", "g3bar"}]]}], ">=",
               "0"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Return", "[", "True", "]"}], ";"}]}], 
           "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Grzadkowski", ",", " ", 
            RowBox[{
             RowBox[{
             "Ogreid", " ", "and", " ", "Osland", " ", "sufficient", " ", 
              "conditions", " ", "from", " ", 
              RowBox[{"https", ":"}]}], "//", 
             RowBox[{
              RowBox[{
               RowBox[{"arxiv", ".", "org"}], "/", "pdf"}], "/", 
              "0904.2173"}]}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"f1", "=", 
           RowBox[{"b1", "+", 
            RowBox[{"Min", "[", 
             RowBox[{"0", ",", 
              RowBox[{"c1", "-", 
               RowBox[{"Abs", "[", "d1", "]"}]}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"f2", "=", 
           RowBox[{"b2", "+", 
            RowBox[{"Min", "[", 
             RowBox[{"0", ",", 
              RowBox[{"c2", "-", 
               RowBox[{"Abs", "[", "d2", "]"}]}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"f3", "=", 
           RowBox[{"b3", "+", 
            RowBox[{"Min", "[", 
             RowBox[{"0", ",", 
              RowBox[{"c3", "-", 
               RowBox[{"Abs", "[", "d3", "]"}]}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"f1", "+", 
               SqrtBox[
                RowBox[{"a2", " ", "a3"}]]}], ">=", "0"}], "&&", 
             RowBox[{
              RowBox[{"f2", "+", 
               SqrtBox[
                RowBox[{"a3", " ", "a1"}]]}], ">=", "0"}], "&&", 
             RowBox[{
              RowBox[{"f3", "+", 
               SqrtBox[
                RowBox[{"a1", " ", "a2"}]]}], ">=", "0"}], "&&", 
             "\[IndentingNewLine]", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"f1", 
                  SqrtBox["a1"]}], "+", 
                 RowBox[{"f2", 
                  SqrtBox["a2"]}], "+", 
                 RowBox[{"f3", 
                  SqrtBox["a3"]}]}], ">=", "0"}], "||", 
               RowBox[{
                RowBox[{
                 RowBox[{"a1", " ", "a2", " ", "a3"}], "+", 
                 RowBox[{"2", "f1", " ", "f2", " ", "f3"}], "-", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"a1", " ", 
                    SuperscriptBox["f1", "2"]}], "+", 
                   RowBox[{"a2", " ", 
                    SuperscriptBox["f2", "2"]}], "+", 
                   RowBox[{"a3", " ", 
                    SuperscriptBox["f3", "2"]}]}], ")"}]}], ">=", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Return", "[", "True", "]"}], ";"}]}], 
           "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", "False"}]}], "\[IndentingNewLine]", "]"}], 
       ",", 
       RowBox[{"Parallelization", "\[Rule]", "True"}], ",", 
       RowBox[{"CompilationTarget", "\[Rule]", "wpCompTargetPac"}]}], 
      "]"}]}]}], "]"}], ";"}]], "Input",
