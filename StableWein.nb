Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"wbLoadBinariesPac", ",", 
    RowBox[{"wbWeinParRnd", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"wbBinDirect", ",", "\"\<wbWeinParRnd.wdx\>\""}], "}"}], 
       "]"}], "]"}]}], ",", 
    RowBox[{"wbWeinParRnd", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"bnd", ",", "_Real"}], "}"}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
           "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3", ",", 
           "\[Epsilon]"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"a1", ",", "a2", ",", "a3"}], "}"}], "=", 
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "bnd"}], ",", "bnd"}], "}"}], ",", "3"}], "]"}]}],
           ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "b1", ",", "b2", ",", "b3", ",", "c1", ",", "c2", ",", "c3", ",", 
             "d1", ",", "d2", ",", "d3"}], "}"}], "=", 
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "bnd"}], ",", "bnd"}], "}"}], ",", "9"}], "]"}]}],
           ";", "\[IndentingNewLine]", 
          RowBox[{"\[Epsilon]", "=", 
           RowBox[{"RandomReal", "[", 
            RowBox[{"{", 
             RowBox[{"0.", ",", 
              RowBox[{"2.", "*", "Pi"}]}], "}"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
           "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
            "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3", ",", 
            "\[Epsilon]"}], "}"}]}]}], "\[IndentingNewLine]", "]"}], ",", 
       RowBox[{"Parallelization", "\[Rule]", "True"}], ",", 
       RowBox[{"CompilationTarget", "\[Rule]", "wpCompTargetPac"}]}], 
      "]"}]}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.976718643278512*^9, 3.976718711848989*^9}, {
   3.97671875586497*^9, 3.976718787359255*^9}, 3.976720203618895*^9, {
