                 "\[IndentingNewLine]", 
                 RowBox[{"Do", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"netPred", "=", 
                    RowBox[{
                    RowBox[{"wbNetWeinList", "[", 
                    RowBox[{"[", "xx", "]"}], "]"}], "[", "dataT", "]"}]}], 
                    ";", "\[IndentingNewLine]", 
                    RowBox[{"dataT", "=", 
                    RowBox[{"DeleteCases", "[", 
                    RowBox[{
                    RowBox[{"Thread", "[", 
                    RowBox[{"dataT", "->", "netPred"}], "]"}], ",", 
                    RowBox[{"_", "->", "0"}]}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "dataT", "]"}], "==", "0"}], ",", 
                    RowBox[{"dataT", "=", 
                    RowBox[{"{", 
