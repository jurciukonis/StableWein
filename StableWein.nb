       RowBox[{"{", 
        RowBox[{"wbBinDirect", ",", "\"\<wbWeinNecCond1.wdx\>\""}], "}"}], 
       "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"wbWeinNecCond1", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"par", ",", "_Real", ",", "1"}], "}"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a1", ",", "b1", ",", "c1", ",", "d1", ",", "a2", ",", "b2", ",", 
           "c2", ",", "d2", ",", "a3", ",", "b3", ",", "c3", ",", "d3", ",", 
           "\[Epsilon]"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
             "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3", ",",
              "\[Epsilon]"}], "}"}], "=", "par"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"a1", "<", "0"}], "||", "\[IndentingNewLine]", 
             RowBox[{"a2", "<", "0"}], "||", "\[IndentingNewLine]", 
             RowBox[{"a3", "<", "0"}], "||", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b1", "+", 
               SqrtBox[
                RowBox[{"a2", " ", "a3"}]]}], "<", "0"}], "||", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b2", "+", 
               SqrtBox[
                RowBox[{"a3", " ", "a1"}]]}], "<", "0"}], "||", 
             "\[IndentingNewLine]", 
             RowBox[{
