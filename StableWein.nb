Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"wbLoadBinariesPac", ",", 
    RowBox[{"wbBrancNecCond1", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"wbBinDirect", ",", "\"\<wbBrancNecCond1.wdx\>\""}], "}"}], 
       "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"wbBrancNecCond1", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"par", ",", "_Real", ",", "1"}], "}"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a1", ",", "b1", ",", "c1", ",", "d1", ",", "a2", ",", "b2", ",", 
           "c2", ",", "d2", ",", "a3", ",", "b3", ",", "c3", ",", "d3"}], 
          "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
             "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3"}], 
            "}"}], "=", "par"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"a1", "<", "0"}], "||", "\[IndentingNewLine]", 
             RowBox[{"a2", "<", "0"}], "||", "\[IndentingNewLine]", 
             RowBox[{"a3", "<", "0"}], "||", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b1", "+", 
               SqrtBox[
                RowBox[{"a2", " ", "a3"}]]}], "<", "0"}], "||", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b2", "+", 
               SqrtBox[
                RowBox[{"a3", " ", "a1"}]]}], "<", "0"}], "||", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b3", "+", 
               SqrtBox[
                RowBox[{"a1", " ", "a2"}]]}], "<", "0"}], "||", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b1", "+", 
               SqrtBox[
                RowBox[{"a2", " ", "a3"}]], "+", "c1", "-", 
               RowBox[{"Abs", "[", "d1", "]"}]}], "<", "0"}], "||", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b2", "+", 
               SqrtBox[
                RowBox[{"a1", " ", "a3"}]], "+", "c2", "-", 
               RowBox[{"Abs", "[", "d2", "]"}]}], "<", "0"}], "||", 
             "\[IndentingNewLine]", 
