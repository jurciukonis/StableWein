Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"wbLoadBinariesPac", ",", 
    RowBox[{"wbBrancParRnd", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"wbBinDirect", ",", "\"\<wbBrancParRnd.wdx\>\""}], "}"}], 
       "]"}], "]"}]}], ",", 
    RowBox[{"wbBrancParRnd", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"bnd", ",", "_Real"}], "}"}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
           "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3"}], 
          "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"a1", ",", "a2", ",", "a3"}], "}"}], "=", 
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "bnd"}], ",", "bnd"}], "}"}], ",", "3"}], "]"}]}],
           ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "b1", ",", "b2", ",", "b3", ",", "c1", ",", "c2", ",", "c3", ",", 
             "d1", ",", "d2", ",", "d3"}], "}"}], "=", 
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "bnd"}], ",", "bnd"}], "}"}], ",", "9"}], "]"}]}],
           ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
           "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
            "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3"}], 
           "}"}]}]}], "\[IndentingNewLine]", "]"}], ",", 
