     RowBox[{"\"\<BoundUNI\>\"", "\[Rule]", 
      RowBox[{"8", " ", "\[Pi]"}]}], ",", 
     RowBox[{"\"\<FileNameInit\>\"", "\[Rule]", "\"\<initial_set.csv\>\""}], 
