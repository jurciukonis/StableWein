Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"wbWeinGridGen", "[", "steps_", "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ratNb", ",", "step\[Theta]", ",", "step1", ",", "step2", ",", "step3", 
       ",", "wbfaceListWein", ",", "wb\[Theta]ListWein", ",", 
       "wb\[Theta]ListWein2"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"step1", ",", "step2", ",", "step3"}], "}"}], "=", "steps"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"ratNb", "=", 
       RowBox[{"N", "@", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Flatten", "@", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"x", "/", "y"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "1", ",", "y"}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"y", ",", "1", ",", "step1"}], "}"}]}], "]"}]}]}]}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"wbfaceListWein", "=", 
       RowBox[{"DeleteDuplicates", "@", 
        RowBox[{"Chop", "@", 
         RowBox[{"N", "@", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"wbFaceFunc", "/@", "ratNb"}], ",", "1"}], "]"}]}]}]}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"step\[Theta]", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Pi", "/", "x"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "1", ",", "step2"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"wb\[Theta]ListWein", "=", 
       RowBox[{"N", "@", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"wbAnglFunc", "/@", "step\[Theta]"}], ",", "1"}], 
          "]"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"step\[Theta]", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Pi", "/", "x"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "1", ",", "step3"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"wb\[Theta]ListWein2", "=", 
       RowBox[{"N", "@", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{"\[Theta]3", ",", 
               RowBox[{"{", 
                RowBox[{"\[Theta]3", ",", "0", ",", 
                 RowBox[{"2", " ", "Pi"}], ",", "#"}], "}"}]}], "]"}], "&"}], 
            "/@", "step\[Theta]"}], ",", "1"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Number of points in Weinberg's grids: \>\"", "<>", 
        RowBox[{"ToString", "@", 
         RowBox[{"(", 
          RowBox[{"Length", "/@", 
           RowBox[{"{", 
            RowBox[{
            "wbfaceListWein", ",", "wb\[Theta]ListWein", ",", 
