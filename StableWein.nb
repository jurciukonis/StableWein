Cell[TextData[{
 StyleBox["StableWein",
  FontWeight->"Bold"],
 ": Software for evaluating perturbative unitarity (UNI) and \
bounded-from-below (BFB) conditions in Weinberg\[CloseCurlyQuote]s model ",
 ButtonBox["[1]",
  BaseStyle->"Hyperlink",
  ButtonData->"References"],
 " and Branco\[CloseCurlyQuote]s model ",
 ButtonBox["[2]",
  BaseStyle->"Hyperlink",
  ButtonData->"References"],
 ", implemented following Ref. ",
 ButtonBox["[3]",
  BaseStyle->"Hyperlink",
  ButtonData->"References"],
 ".\nCopyright, 2026  D. ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Jur\[CHacek]iukonis", "1"], TraditionalForm]],
  ExpressionUUID->"6a7d44e2-afdc-4a97-a5d3-e95a5f41f832"],
 ", L. ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Lavoura", "2"], TraditionalForm]],ExpressionUUID->
  "40871eb8-f909-4089-a9fc-36cc634507f0"],
 ", and A. ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Milagre", "3"], TraditionalForm]],ExpressionUUID->
  "132f4502-0b1b-4c6e-8883-5d28c4a68a83"],
 ", \n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[InvisiblePrefixScriptBase]", "1"], 
     StyleBox["E",
      FontSlant->"Plain"]}], "-", "mail"}], TraditionalForm]],ExpressionUUID->
  "26109e8d-f70a-4729-a88c-d6dd79045dc3"],
 ": darius.jurciukonis@tfai.vu.lt\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
