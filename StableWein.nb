                RowBox[{"a1", " ", "a2"}]], "+", "c3", "-", 
               RowBox[{"Abs", "[", "d3", "]"}]}], "<", "0"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Return", "[", "False", "]"}], ";"}]}], 
