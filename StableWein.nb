Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{"wbLoadBinariesPac", ",", 
    RowBox[{"wbBrancNecCond3", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"wbBinDirect", ",", "\"\<wbBrancNecCond3.wdx\>\""}], "}"}], 
       "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"wbBrancNecCond3", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"par", ",", "_Real", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"faceList", ",", "_Real", ",", "2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Theta]List", ",", "_Real", ",", "2"}], "}"}]}], "}"}], 
       ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "a1", ",", "a2", ",", "a3", ",", "b1", ",", "b2", ",", "b3", ",", 
           "c1", ",", "c2", ",", "c3", ",", "d1", ",", "d2", ",", "d3", ",", 
           "t1", ",", "t2", ",", "t3", ",", "y1", ",", "y2", ",", "y3", ",", 
           "z1", ",", "z2", ",", "z3", ",", "sqa1", ",", "sqa2", ",", "sqa3", 
           ",", "at", ",", "test1", ",", "test2", ",", "w1", ",", "w2", ",", 
           "w3", ",", "\[Theta]", ",", "\[Theta]1", ",", "\[Theta]2", ",", 
           "\[Theta]3"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
