Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"wbNearDelFunc", "[", 
    RowBox[{"faceList_", ",", "step_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"listT", ",", "nb", ",", "nearList", ",", "delList"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"listT", "=", "faceList"}], ";", " ", 
      RowBox[{"nb", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "listT", "]"}], ">=", "nb"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"nearList", "=", 
          RowBox[{"Nearest", "[", 
           RowBox[{"listT", ",", 
            RowBox[{"listT", "[", 
             RowBox[{"[", "nb", "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              SuperscriptBox["10", "3"], ",", "step"}], "}"}]}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "nearList", "]"}], ">", "1"}], ",", 
           RowBox[{"delList", "=", 
            RowBox[{"nearList", "[", 
             RowBox[{"[", 
              RowBox[{"2", ";;"}], "]"}], "]"}]}], ",", 
           RowBox[{"delList", "=", 
            RowBox[{"{", "}"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"listT", "=", 
          RowBox[{"Complement", "[", 
           RowBox[{"listT", ",", "delList"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"nb", "=", 
          RowBox[{"nb", "+", "1"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], 
      ";", "\[IndentingNewLine]", "listT"}]}], "\[IndentingNewLine]", "]"}]}],
   ";"}]], "Input",
