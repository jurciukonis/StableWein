           "Ab1", ",", "Ab2", ",", "Ab3", ",", "Ac1", ",", "Ac2", ",", "Ac3", 
            ",", "Ad1", ",", "Ad2", ",", "Ad3"}], "}"}], "=", 
          RowBox[{"Abs", "/@", 
           RowBox[{"{", 
