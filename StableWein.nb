                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"ValidSetTmp", "[", 
                    RowBox[{"[", "xx", "]"}], "]"}], ",", " ", 
                    RowBox[{"wbMinimFuncPotWein", "[", 
                    RowBox[{
                    RowBox[{"ValidSetTmp", "[", 
                    RowBox[{"[", "xx", "]"}], "]"}], ",", "bndT"}], "]"}]}], 
                    "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"xx", ",", "1", ",", 
                    RowBox[{"Length", "[", "ValidSetTmp", "]"}]}], "}"}]}], 
                   "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"_", ",", "False"}], "}"}]}], "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{";;", ",", "1"}], "]"}], "]"}]}], ";"}], "*)"}], 
            "\[IndentingNewLine]", 
            RowBox[{"validSet", "=", 
             RowBox[{"Join", "[", 
              RowBox[{"trueBFB", ",", "validSet"}], "]"}]}], ";"}], 
           "\[IndentingNewLine]", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"ShowMessages", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"mode", "==", "4"}], ",", 
           RowBox[{"Print", "[", 
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{
              "\"\<Run time of the potential minimization (mode \>\"", "<>", 
               RowBox[{"ToString", "[", "mode", "]"}], "<>", "\"\<): \>\"", "<>",
                " ", 
