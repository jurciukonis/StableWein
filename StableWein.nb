   RowBox[{"wbBrancGridGen", "[", "steps_", "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ratNb", ",", "step\[Theta]", ",", "step1", ",", "step2", ",", "step3", 
       ",", "wbfaceListBranc", ",", "wb\[Theta]ListBranc"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"step1", ",", "step2"}], "}"}], "=", "steps"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ratNb", "=", 
       RowBox[{"N", "@", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Flatten", "@", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"x", "/", "y"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "1", ",", "y"}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"y", ",", "1", ",", "step1"}], "}"}]}], "]"}]}]}]}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"wbfaceListBranc", "=", 
       RowBox[{"DeleteDuplicates", "@", 
        RowBox[{"Chop", "@", 
         RowBox[{"N", "@", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"wbFaceFunc", "/@", "ratNb"}], ",", "1"}], "]"}]}]}]}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"step\[Theta]", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Pi", "/", "x"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "1", ",", "step2"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"wb\[Theta]ListBranc", "=", 
       RowBox[{"N", "@", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"wbAnglFunc", "/@", "step\[Theta]"}], ",", "1"}], 
          "]"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Number of points in Branco's grids: \>\"", "<>", 
        RowBox[{"ToString", "@", 
         RowBox[{"(", 
          RowBox[{"Length", "/@", 
           RowBox[{"{", 
            RowBox[{"wbfaceListBranc", ",", "wb\[Theta]ListBranc"}], "}"}]}], 
          ")"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"wbfaceListBranc", ",", "wb\[Theta]ListBranc"}], "}"}]}]}], 
    "]"}]}], ";"}]], "Input",
