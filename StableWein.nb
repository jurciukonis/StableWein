Cell["\<\
Here is the list of options that can be used to modify global package \
function definitions. Short descriptions and status are given below.\
\>", "Text",
 CellChangeTimes->{{3.978783728452437*^9, 
  3.978783730095154*^9}},ExpressionUUID->"831284f9-06a8-46e6-af07-\
3e502b4af3ba"],

Cell[TextData[{
 "To speed up the computations, we neither define the package through command \
",
 ButtonBox["BeginPackage",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/BeginPackage"],
 " nor use context-manipulation commands. Instead, we use global functions \
whose names begin with the prefix \[OpenCurlyDoubleQuote]wp\
\[CloseCurlyDoubleQuote], along with global variables corresponding to the \
package definitions."
}], "Text",
 CellChangeTimes->{{3.978785248849334*^9, 3.9787852638834248`*^9}, {
  3.9787853617606277`*^9, 3.978785485603827*^9}, {3.978785528558547*^9, 
  3.978785547052513*^9}, {3.979294881005863*^9, 3.979294901549149*^9}, {
