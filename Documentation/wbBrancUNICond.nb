Cell[TextData[{
 "Filter the couplings according to the UNI conditions given in Refs. ",
 ButtonBox["[1, 2]",
  BaseStyle->"Hyperlink",
  ButtonData->"References"],
 ". The eigenvalues of the scattering matrix are bounded by a quantity ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "max"], TraditionalForm]],ExpressionUUID->
  "c1114c30-ff3b-4b4d-8720-8ebe47774457"],
 ", which is typically taken to be 8\[Pi]. Return: False | True."
}], "UsageInputs",
 CellChangeTimes->{{3.979035504354062*^9, 3.979035512979663*^9}, {
  3.979045952752843*^9, 3.9790459912986183`*^9}, {3.979046046147887*^9, 
