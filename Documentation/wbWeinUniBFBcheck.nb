   3.9792007897159643`*^9}, 3.97920130114102*^9, 3.979201353432617*^9, {
   3.979273496635736*^9, 3.979273536711228*^9}, 3.979274407245462*^9, {
   3.979889226839362*^9, 3.979889233572255*^9}, {3.980053682735621*^9, 
   3.980053685865698*^9}, 3.98005417761518*^9, {3.980337079878272*^9, 
   3.980337082436146*^9}},
 CellID->167997579,ExpressionUUID->"b7df38c3-cabf-47e5-9a64-a8382913be8f"],

