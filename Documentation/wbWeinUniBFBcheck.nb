Cell[TextData[{
 "Five accuracy modes are available for BFB filtering:\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 0, the sufficient BFB conditions are imposed using the function ",
 ButtonBox["wbWeinSufCond",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 1, the necessary 2HDM BFB conditions (NCL1) are imposed using the \
function ",
 ButtonBox["wbWeinNecCond1",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 2, the additional necessary BFB conditions (NCL1-NCL3) are imposed using \
the function ",
 ButtonBox["wbWeinNecCond2",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 3, the additional necessary BFB conditions (NCL1-NCL4) are imposed using \
the function ",
 ButtonBox["wbWeinNecCond3",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 4, the quartic potential is minimized using the function ",
 ButtonBox["wbMinimFuncPotWein",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinMinim.nb", None}]
}], "Notes",
 Editable->True,
 TaggingRules->{},
 CellChangeTimes->{{3.953651088346464*^9, 3.953651090908451*^9}, {
