Cell[TextData[{
 "The \"BoundUNI\" \[Rule] ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "max"], TraditionalForm]],ExpressionUUID->
  "a9d37bf2-67e7-4b92-a306-c045b536c871"],
 " option sets the unitarity bound, i.e. the eigenvalues of the scattering \
matrix are required to be bounded by a quantity ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "max"], TraditionalForm]],ExpressionUUID->
  "9e502f82-8f04-42a7-a19f-3eee3f92ed81"],
 ", which is typically taken to be 8\[Pi]. In some cases, a relaxed unitarity \
bound may be used:"
}], "Text",
