Cell[TextData[{
 "An initial data set satisfying the UNI and BFB conditions can be generated \
using neural networks by setting the option \"NeuralNets\"\[Rule]",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["True", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/True",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "476efed4-f170-462c-a26d-50c919389cc1"],
 "."
}], "Notes",
 CellID->1739050076,ExpressionUUID->"554034f1-a1c8-42f1-a2d7-9c1203b1cc3c"],

Cell[TextData[{
 "The following options can be given:\n\n",
 Cell[BoxData[GridBox[{
    {
     StyleBox["Option",
      FontWeight->"Bold"], 
     StyleBox[
      RowBox[{"Default", " ", "value"}],
      FontWeight->"Bold"], 
     StyleBox["Meaning",
      FontWeight->"Bold"]},
    {
     ButtonBox["GeneratePoints",
      BaseStyle->"Hyperlink",
      ButtonData->"GeneratePoints"], "True", 
     RowBox[{
     "generation", " ", "of", " ", "the", " ", "initial", " ", "dataset"}]},
    {
     ButtonBox["ImposeUNI",
      BaseStyle->"Hyperlink",
      ButtonData->"ImposeUNI"], "True", 
     RowBox[{
     "filter", " ", "the", " ", "couplings", " ", "according", " ", "to", " ",
       "the", " ", "UNI", " ", "conditions"}]},
    {
     ButtonBox["ImposeBFB",
      BaseStyle->"Hyperlink",
      ButtonData->"ImposeBFB"], "True", 
     RowBox[{
     "filter", " ", "the", " ", "couplings", " ", "according", " ", "to", " ",
       "the", " ", "BFB", " ", "conditions"}]},
    {
     ButtonBox["NeuralNets",
      BaseStyle->"Hyperlink",
      ButtonData->"NeuralNets"], "False", 
     RowBox[{"neural", " ", "networks", " ", "are", " ", "used"}]},
    {
     ButtonBox["ExportData",
      BaseStyle->"Hyperlink",
      ButtonData->"Import & Export Data"], "False", 
     RowBox[{
     "the", " ", "initial", " ", "and", " ", "validated", " ", "data", " ", 
      "sets", " ", "are", " ", "exported", " ", "to", " ", "a", " ", "file"}]},
    {
     ButtonBox["ShowMessages",
      BaseStyle->"Hyperlink",
      ButtonData->"ShowMessages"], "True", 
     RowBox[{
     "messages", " ", "reporting", " ", "the", " ", "computation", " ", 
      "times", " ", "and", " ", "results", " ", "are", " ", "displayed"}]},
    {
     ButtonBox["NPoints",
      BaseStyle->"Hyperlink",
      ButtonData->"NPoints"], 
     SuperscriptBox["10", "3"], 
     RowBox[{
     "number", " ", "of", " ", "initial", " ", "points", " ", "in", " ", 
      "the", " ", "dataset"}]},
    {
     ButtonBox["MaxCoupling",
      BaseStyle->"Hyperlink",
      ButtonData->"MaxCoupling"], "16", 
     RowBox[{
     "bounds", " ", "for", " ", "the", " ", "generated", " ", "couplings"}]},
    {
     ButtonBox["BoundUNI",
      BaseStyle->"Hyperlink",
      ButtonData->"BoundUNI"], 
     RowBox[{"8", "\[Pi]"}], 
     RowBox[{"unitarity", " ", "bound"}]},
    {
     ButtonBox["FileNameInit",
      BaseStyle->"Hyperlink",
      ButtonData->"Import & Export Data"], 
     RowBox[{"initial_set", ".", "csv"}], 
     RowBox[{
     "file", " ", "name", " ", "for", " ", "initial", " ", "dataset"}]},
    {
     ButtonBox["FileNameValid",
      BaseStyle->"Hyperlink",
      ButtonData->"Import & Export Data"], 
     RowBox[{"valid_set", ".", "csv"}], 
     RowBox[{
     "file", " ", "name", " ", "for", " ", "validated", " ", "dataset"}]}
   },
   GridBoxDividers->{
    "Columns" -> {{False}}, "Rows" -> {False, {True}, False}}]],
  ExpressionUUID->"e3038b55-3080-4af4-8f9e-ab7c9a666910"]
}], "Notes",
