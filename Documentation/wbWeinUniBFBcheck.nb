Cell[TextData[{
 "Although ",
 ButtonBox["wbWeinUniBFBcheck",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinUniBFBcheck.nb", None}],
 " produces the same results, ",
 ButtonBox["wbBrancUniBFBcheck",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancUniBFBcheck.nb", None}],
 " is more optimized for the CP-conserving case, as reflected by the \
BFB-enforcement runtimes reported above."
}], "Text",
