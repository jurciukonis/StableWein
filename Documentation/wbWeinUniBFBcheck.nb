Cell[TextData[{
 "Generate and filter the couplings according to the UNI and BFB conditions \
using the methods and accuracy prescriptions described in Ref. ",
 ButtonBox["[1]",
  BaseStyle->"Hyperlink",
  ButtonData->"References"],
 ". Return the list of generated (initial) points and the list of validated \
points."
}], "UsageInputs",
 CellChangeTimes->{{3.979035504354062*^9, 3.979035512979663*^9}, {
   3.979045577863702*^9, 3.9790455831373262`*^9}, {3.979135305847438*^9, 
