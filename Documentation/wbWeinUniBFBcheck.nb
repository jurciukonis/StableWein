Cell[TextData[{
 "Because many data formats are possible, we allow users to import the data \
into Mathematica themselves. The imported data can then be passed to ",
 ButtonBox["wbWeinUniBFBcheck",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinUniBFBcheck.nb", None}],
 " by setting the global parameter ",
 "wbParamData",
 "."
}], "Text",
 Editable->True,
 TaggingRules->{},
