Cell[TextData[{
 "With mode = 4, the points in the initial data set are validated by \
minimizing the quartic potential using ",
 ButtonBox["wbMinimFuncPotBranc",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancMinim.nb", None}],
 ". This mode is useful for cross-checking the BFB-validated points obtained \
with mode = 3 and for achieving maximal accuracy. However, potential \
minimization is computationally expensive and requires substantial \
resources:"
}], "Text",
