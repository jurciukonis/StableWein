Cell[TextData[{
 "Because many data formats are possible, we allow users to import the data \
into Mathematica themselves. The imported data can then be passed to ",
 ButtonBox["wbBrancUniBFBcheck",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancUniBFBcheck.nb", None}],
 " by setting the global parameter wbParamData."
}], "Text",
 Editable->True,
 TaggingRules->{},
 CellChangeTimes->{{3.954599430847682*^9, 3.9545994368102837`*^9}, {
