   3.979889184203796*^9}, {3.980053779960292*^9, 3.980053780185713*^9}, {
   3.982404789845014*^9, 3.98240478995232*^9}},
 CellID->167997579,ExpressionUUID->"0b8a4eb0-1e40-4c3f-85db-4f1abf8d418c"],

