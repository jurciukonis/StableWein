   3.9792746677021313`*^9, {3.9798148452792397`*^9, 3.979814871575604*^9}, {
   3.979817019642877*^9, 3.979817035790234*^9}, 3.979817434118469*^9, {
   3.979821148818471*^9, 3.979821153431204*^9}, {3.979826479388816*^9, 
   3.979826485479328*^9}, {3.979889105405723*^9, 3.979889107092935*^9}, {
