Cell[TextData[{
 "Four accuracy modes are available for BFB filtering:\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 0, the sufficient BFB conditions are imposed using the function ",
 ButtonBox["wbBrancSufCond",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 1, the necessary 2HDM BFB conditions (NCL1) are imposed using the \
function ",
 ButtonBox["wbBrancNecCond1",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 2, the additional necessary BFB conditions (NCL1-NCL3) are imposed using \
the function ",
 ButtonBox["wbBrancNecCond2",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 3, the additional necessary BFB conditions (NCL1-NCL4) are imposed using \
the function ",
 ButtonBox["wbBrancNecCond3",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancBFBCond.nb", None}],
 "\nfor ",
 StyleBox["mode",
  FontSlant->"Italic"],
 " = 4, the quartic potential is minimized using the function ",
 ButtonBox["wbMinimFuncPotBranc",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancMinim.nb", None}]
}], "Notes",
 Editable->True,
 TaggingRules->{},
 CellChangeTimes->{{3.953651088346464*^9, 3.953651090908451*^9}, {
