   3.9800534380872393`*^9, 3.980053649953703*^9, 3.980100449017223*^9, {
   3.980339711635412*^9, 3.98033971443305*^9}},
 CellID->167997579,ExpressionUUID->"8fcb01e6-7621-4c9c-81ed-57cc4df483f3"],

