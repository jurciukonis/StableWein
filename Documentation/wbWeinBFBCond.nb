Cell[TextData[{
 "Note that, in combination with ",
 ButtonBox["wbWeinSufCond",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinBFBCond.nb", None}],
 " and ",
 ButtonBox["wbWeinNecCond2",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinBFBCond.nb", None}],
 ", the function ",
 ButtonBox["wbWeinNecCond3",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinBFBCond.nb", None}],
 " yields highly accurate results even with the default grids, as can be seen \
in ",
 ButtonBox["wbWeinUniBFBcheck",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbWeinUniBFBcheck.nb", None}],
 "."
}], "Text",
