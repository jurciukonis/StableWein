Cell[BoxData[{
 RowBox[{
  RowBox[{"dataUniNec1", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"testT", "=", "False"}], ";", " ", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"testT", "==", "False"}], ",", 
        RowBox[{
         RowBox[{"paramT", "=", 
          RowBox[{"wbWeinParRndUniNec", "[", "]"}]}], ";", " ", 
         RowBox[{"testT", "=", 
          RowBox[{"wbWeinUNINec1Cond", "[", 
           RowBox[{"paramT", ",", 
            RowBox[{"8.", "*", "Pi"}]}], "]"}]}]}]}], "]"}], ";", " ", 
      "paramT"}], ",", 
     RowBox[{"{", 
      SuperscriptBox["10", "6"], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataUniNec2", "=", 
   RowBox[{"Pick", "[", 
    RowBox[{"dataUniNec1", ",", 
     RowBox[{"ParallelMap", "[", 
      RowBox[{"wbWeinNecCond2", ",", "dataUniNec1"}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataUniSuf", "=", 
   RowBox[{"Pick", "[", 
    RowBox[{"dataUniNec1", ",", 
     RowBox[{"ParallelMap", "[", 
      RowBox[{"wbWeinSufCond", ",", "dataUniNec1"}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Length", "/@", 
  RowBox[{"{", 
   RowBox[{"dataUniNec1", ",", "dataUniNec2", ",", "dataUniSuf"}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"PercentForm", "/@", 
  RowBox[{"N", "[", 
   RowBox[{"%", "/", 
    RowBox[{"Length", "[", "dataUniNec1", "]"}]}], "]"}]}]}], "Input",
