Cell[TextData[StyleBox["function that minimizes the quartic scalar potential \
of Branco\[CloseCurlyQuote]s model. If the minimum value of the potential is \
positive, the chosen set of couplings satisfies the BFB conditions.",
 FontSize->16]], "Text",
 Editable->True,
 Deletable->True,
