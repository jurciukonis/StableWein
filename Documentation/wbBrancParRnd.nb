Cell[TextData[{
 "This function random-generates the couplings of the quartic scalar \
potential in the format ",
 StyleBox[" ",
  FontFamily->"Source Sans Pro"],
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["a", "1"]}], TraditionalForm]],ExpressionUUID->
  "42a1f19c-9909-4fb3-8984-51aca2c4559b"],
