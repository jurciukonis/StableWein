Cell[TextData[{
 "Note that, in combination with ",
 ButtonBox["wbBrancSufCond",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancBFBCond.nb", None}],
 " and ",
 ButtonBox["wbBrancNecCond2",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancBFBCond.nb", None}],
 ", the function ",
 ButtonBox["wbBrancNecCond3",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancBFBCond.nb", None}],
 " yields highly accurate results even with the default grids, as can be seen \
in ",
 ButtonBox["wbBrancUniBFBcheck",
  BaseStyle->"Hyperlink",
  ButtonData->{"wbBrancUniBFBcheck.nb", None}],
 "."
}], "Text",
